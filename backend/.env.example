# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/libcore

# Session secret - change this to a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret

# Port the backend listens on
PORT=3001

# Frontend origin for CORS (adjust if different)
CORS_ORIGIN=http://localhost:5173

# Optional: Stripe keys for payments (leave blank to use demo mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: log level (trace, debug, info, warn, error)
LOG_LEVEL=info
